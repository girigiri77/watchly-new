1: "use client"
2: 
3: import Link from "next/link"
4: import { usePathname } from "next/navigation"
5: import { FormEvent, ReactElement, useEffect, useMemo, useState } from "react"
6: import { Edit3, Film, LayoutDashboard, Menu, Plus, Save, Search, Shield, Trash2, X, TrendingUp, Clock, Star, Monitor, Tags, Sparkles } from "lucide-react"
7: import { MovieImageUpload } from "@/components/admin/MovieImageUpload"
8: import { movies as seedMovies } from "@/data/movies"
9: import { ADMIN_MOVIES_STORAGE_KEY, notifyMoviesUpdated } from "@/lib/admin-movies-storage"
10: import { LANGUAGES, MOODS, OTT_PLATFORMS, type Mood, type MovieCurated, type MovieLanguage, type OTTPlatform } from "@/types/movie"
11: 
12: type DraftMovie = Omit<MovieCurated, "id" | "moods" | "categories" | "homepageRows" | "genre"> & {
13:   id?: number
14:   moods: string[]
15:   categories: string
16:   homepageRows: string
17:   genre: string
18: }
19: 
20: const emptyDraft: DraftMovie = {
21:   tmdbId: 0,
22:   title: "",
23:   moods: ["Emotional"],
24:   ottPlatform: "Netflix",
25:   language: "Telugu",
26:   rating: 8,
27:   youtubeTrailer: "",
28:   featured: false,
29:   categories: "",
30:   year: 2026,
31:   duration: "2h 20m",
32:   weeklyOTTRelease: false,
33:   trending: false,
34:   latestRelease: false,
35:   heroFeatured: false,
36:   editorialTagline: "",
37:   weeklyOrder: 99,
38:   homepageRows: "",
39:   editorialPick: false,
40:   latestMovie: false,
41:   acrossPlatforms: false,
42:   featuredCollection: false,
43:   poster: "https://image.tmdb.org/t/p/w500/placeholder.jpg",
44:   backdrop: "",
45:   customPoster: "",
46:   customBackdrop: "",
47:   overview: "",
48:   releaseDate: "2026-05-12",
49:   genre: "Drama",
50:   gradientAccent: "#7C3AED",
51: }
52: 
53: function toDraft(movie: MovieCurated): DraftMovie {
54:   return {
55:     ...movie,
56:     moods: movie.moods,
57:     categories: movie.categories.join(", "),
58:     homepageRows: movie.homepageRows?.join(", ") ?? "",
59:     genre: movie.genre.join(", "),
60:   }
61: }
62: 
63: function toMovie(draft: DraftMovie, fallbackId: number): MovieCurated {
64:   return {
65:     ...draft,
66:     id: draft.id ?? fallbackId,
67:     moods: draft.moods as Mood[],
68:     ottPlatform: draft.ottPlatform as OTTPlatform,
69:     language: draft.language as MovieLanguage,
70:     categories: draft.categories.split(",").map((item) => item.trim()).filter(Boolean),
71:     homepageRows: draft.homepageRows.split(",").map((item) => item.trim()).filter(Boolean),
72:     genre: draft.genre.split(",").map((item) => item.trim()).filter(Boolean),
73:     editorialTagline: draft.editorialTagline || undefined,
74:     backdrop: draft.backdrop || undefined,
75:     customPoster: draft.customPoster?.trim() || undefined,
76:     customBackdrop: draft.customBackdrop?.trim() || undefined,
77:     acrossPlatforms: false,
78:     featuredCollection: false,
79:   }
80: }
81: 
82: function getMoodEmoji(mood: Mood): string {
83:   const moodEmojiMap: Record<Mood, string> = {
84:     Love: "❤️",
85:     Emotional: "🥹",
86:     Mass: "🔥",
87:     Thriller: "🕵️",
88:     Action: "💥",
89:     "Feel Good": "✨",
90:     Comedy: "😂",
91:     Dark: "🌑",
92:     Motivational: "🏆",
93:     Family: "👨‍👩‍👧‍👦",
94:     "Sci-Fi": "🚀",
95:     "Mind Bending": "🧠",
96:   }
97: 
98:   return moodEmojiMap[mood] ?? "🎬"
99: }
100: 
101: export default function AdminPage() {
102:   const pathname = usePathname()
103:   /** Same initial data on server and client to avoid hydration mismatches; localStorage is applied after mount. */
104:   const [movies, setMovies] = useState<MovieCurated[]>(seedMovies)
105:   const [storageHydrated, setStorageHydrated] = useState(false)
106:   const [query, setQuery] = useState("")
107:   const [platformFilter, setPlatformFilter] = useState<OTTPlatform | "All">("All")
108:   const [moodFilter, setMoodFilter] = useState<Mood | "All">("All")
109:   const [modalOpen, setModalOpen] = useState(false)
110:   const [draft, setDraft] = useState<DraftMovie>(emptyDraft)
111:   const [activeSection, setActiveSection] = useState("dashboard")
112:   const [sidebarOpen, setSidebarOpen] = useState(false)
113: 
114:   useEffect(() => {
115:     try {
116:       const raw = window.localStorage.getItem(ADMIN_MOVIES_STORAGE_KEY)
117:       if (raw) {
118:         const parsed = JSON.parse(raw) as unknown
119:         if (Array.isArray(parsed) && parsed.length > 0) {
120:           setMovies(parsed as MovieCurated[])
121:         }
122:       }
123:     } catch {
124:       /* keep seed */
125:     }
126:     setStorageHydrated(true)
127:   }, [])
128: 
129:   useEffect(() => {
130:     if (!storageHydrated) return
131:     window.localStorage.setItem(ADMIN_MOVIES_STORAGE_KEY, JSON.stringify(movies))
132:     notifyMoviesUpdated()
133:   }, [movies, storageHydrated])
134: 
135:   const filteredMovies = useMemo(() => {
136:     return movies.filter((movie) => {
137:       const matchesQuery = movie.title.toLowerCase().includes(query.toLowerCase())
138:       const matchesPlatform = platformFilter === "All" || movie.ottPlatform === platformFilter
139:       const matchesMood = moodFilter === "All" || movie.moods.includes(moodFilter)
140:       return matchesQuery && matchesPlatform && matchesMood
141:     })
142:   }, [movies, moodFilter, platformFilter, query])
143: 
144:   const weeklyMovies = useMemo(
145:     () => movies.filter((movie) => movie.weeklyOTTRelease).sort((a, b) => (a.weeklyOrder ?? 999) - (b.weeklyOrder ?? 999)),
146:     [movies],
147:   )
148: 
149:   const stats = useMemo(() => ({
150:     totalMovies: movies.length,
151:     weeklyReleases: movies.filter(m => m.weeklyOTTRelease).length,
152:     featuredMovies: movies.filter(m => m.featured).length,
153:     platforms: new Set(movies.map(m => m.ottPlatform)).size,
154:   }), [movies])
155: 
156:   const openCreate = () => {
157:     setDraft(emptyDraft)
158:     setModalOpen(true)
159:   }
160: 
161:   const openCreateWithMoods = (moods: Mood[]) => {
162:     setDraft({ ...emptyDraft, moods: moods.length > 0 ? moods : (emptyDraft.moods as Mood[]) })
163:     setModalOpen(true)
164:   }
165: 
166:   const goToMovieLibraryForMood = (mood: Mood) => {
167:     setMoodFilter(mood)
168:     setPlatformFilter("All")
169:     setQuery("")
170:     setActiveSection("movies")
171:     setSidebarOpen(false)
172:   }
173: 
174:   const openEdit = (movie: MovieCurated) => {
175:     setDraft(toDraft(movie))
176:     setModalOpen(true)
177:   }
178: 
179:   const saveMovie = (event: FormEvent) => {
180:     event.preventDefault()
181:     const nextId = Math.max(0, ...movies.map((movie) => movie.id)) + 1
182:     const savedMovie = toMovie(draft, nextId)
183: 
184:     setMovies((current) => {
185:       const exists = current.some((movie) => movie.id === savedMovie.id)
186:       return exists ? current.map((movie) => (movie.id === savedMovie.id ? savedMovie : movie)) : [savedMovie, ...current]
187:     })
188:     setModalOpen(false)
189:   }
190: 
191:   const updateMovie = (id: number, patch: Partial<MovieCurated>) => {
192:     setMovies((current) => current.map((movie) => (movie.id === id ? { ...movie, ...patch } : movie)))
193:   }
194: 
195:   const deleteMovie = (id: number) => {
196:     setMovies((current) => current.filter((movie) => movie.id !== id))
197:   }
198: 
199:   const moveWeekly = (id: number, direction: -1 | 1) => {
200:     const ordered = weeklyMovies.map((movie) => movie.id)
201:     const index = ordered.indexOf(id)
202:     const target = index + direction
203:     if (target < 0 || target >= ordered.length) return
204:     const swapped = [...ordered]
205:     ;[swapped[index], swapped[target]] = [swapped[target], swapped[index]]
206:     setMovies((current) =>
207:       current.map((movie) =>
208:         swapped.includes(movie.id) ? { ...movie, weeklyOrder: swapped.indexOf(movie.id) + 1 } : movie,
209:       ),
210:     )
211:   }
212: 
213:   async function signOut() {
214:     setSidebarOpen(false)
215:     await fetch("/api/admin/logout", { method: "POST" })
216:     window.location.href = "/admin/login"
217:   }
218: 
219:   return (
220:     <main className="relative flex min-h-screen bg-[#FAFAF7] text-[#111827]">
221:       {sidebarOpen && (
222:         <button
223:           type="button"
224:           aria-label="Close menu"
225:           className="fixed inset-0 z-40 bg-[#111827]/25 backdrop-blur-[2px] lg:hidden"
226:           onClick={() => setSidebarOpen(false)}
227:         />
228:       )}
229: 
230:       <div className="flex w-full">
231:         <aside
232:           className={`fixed inset-y-0 left-0 z-50 flex w-64 flex-shrink-0 flex-col border-r border-[rgba(124,58,237,0.1)] bg-white shadow-[0_8px_40px_rgba(0,0,0,0.08)] transition-transform duration-200 ease-out lg:static lg:z-0 lg:translate-x-0 lg:shadow-none ${
233:             sidebarOpen ? "translate-x-0" : "-translate-x-full lg:translate-x-0"
234:           }`}
235:         >
236:           <div className="flex items-center justify-between gap-3 border-b border-[rgba(124,58,237,0.1)] p-6">
237:             <div className="flex items-center gap-3">
238:               <div className="flex h-10 w-10 items-center justify-center rounded-xl bg-[#7C3AED] text-white shadow-[0_8px_24px_rgba(124,58,237,0.35)]">
239:                 <Film size={18} />
240:               </div>
241:               <div>
242:                 <div className="font-playfair text-lg font-bold text-[#111827]">Absolute</div>
243:                 <div className="text-[10px] font-bold uppercase tracking-[0.2em] text-[#7C3AED]">Cinema Admin</div>
244:               </div>
245:             </div>
246:             <button
247:               type="button"
248:               className="rounded-lg p-2 text-[#6B7280] hover:bg-[#F3F4F6] lg:hidden"
249:               onClick={() => setSidebarOpen(false)}
250:               aria-label="Close sidebar"
251:             >
252:               <X size={20} />
253:             </button>
254:           </div>
255: 
256:           <nav className="flex-1 space-y-1 p-4">
257:             {[
258:               { id: "dashboard", label: "Dashboard", icon: LayoutDashboard },
259:               { id: "movies", label: "Movies", icon: Film },
260:               { id: "moods", label: "Moods", icon: Tags },
261:               { id: "weekly", label: "Weekly Releases", icon: Clock },
262:               { id: "latest", label: "Latest Movies", icon: TrendingUp },
263:             ].map((item) => (
264:               <button
265:                 key={item.id}
266:                 type="button"
267:                 onClick={() => {
268:                   setActiveSection(item.id)
269:                   setSidebarOpen(false)
270:                 }}
271:                 className={`flex w-full items-center gap-3 rounded-lg px-4 py-3 text-sm font-medium transition-colors ${
272:                   activeSection === item.id
273:                     ? "bg-[#7C3AED] text-white shadow-[0_4px_16px_rgba(124,58,237,0.35)]"
274:                     : "text-[#4B5563] hover:bg-[#F3F4F6] hover:text-[#111827]"
275:                 }`}
276:               >
277:                 <item.icon size={16} />
278:                 {item.label}
279:               </button>
280:             ))}
281:             <Link
282:               href="/admin/telugu-picks"
283:               onClick={() => setSidebarOpen(false)}
284:               className={`flex w-full items-center gap-3 rounded-lg px-4 py-3 text-sm font-medium transition-colors ${
285:                 pathname.startsWith("/admin/telugu-picks")
286:                   ? "bg-[#7C3AED] text-white shadow-[0_4px_16px_rgba(124,58,237,0.35)]"
287:                   : "text-[#4B5563] hover:bg-[#F3F4F6] hover:text-[#111827]"
288:               }`}
289:             >
290:               <Sparkles size={16} />
291:               Telugu Picks
292:             </Link>
293:           </nav>
294: 
295:           <div className="border-t border-[rgba(124,58,237,0.1)] p-4">
296:             <button
297:               type="button"
298:               onClick={() => void signOut()}
299:               className="flex w-full items-center gap-3 rounded-lg px-4 py-3 text-sm font-medium text-[#4B5563] transition-colors hover:bg-[#F3F4F6] hover:text-[#111827]"
300:             >
301:               <Shield size={16} />
302:               Sign out
303:             </button>
304:           </div>
305:         </aside>
306: 
307:         <div className="flex min-w-0 flex-1 flex-col lg:ml-0">
308:           <header className="flex h-16 flex-shrink-0 items-center justify-between border-b border-[rgba(124,58,237,0.1)] bg-white/90 px-4 backdrop-blur-md sm:px-6">
309:             <div className="flex min-w-0 items-center gap-3">
310:               <button
311:                 type="button"
312:                 className="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-full border border-[rgba(124,58,237,0.15)] bg-white text-[#4B5563] shadow-sm transition hover:border-[#7C3AED]/40 hover:text-[#111827] lg:hidden"
313:                 onClick={() => setSidebarOpen(true)}
314:                 aria-label="Open menu"
315:               >
316:                 <Menu size={20} />
317:               </button>
318:               <h1 className="truncate text-lg font-semibold capitalize text-[#111827] sm:text-xl">{activeSection}</h1>
319:               <Link
320:                 href="/"
321:                 className="ml-2 hidden shrink-0 text-sm font-medium text-[#7C3AED] underline-offset-4 hover:underline md:inline"
322:               >
323:                 View site
324:               </Link>
325:             </div>
326:             <div className="flex flex-shrink-0 items-center gap-2 sm:gap-4">
327:               <div className="relative hidden sm:block">
328:                 <Search size={16} className="pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 text-[#9CA3AF]" />
329:                 <input
330:                   value={query}
331:                   onChange={(event) => setQuery(event.target.value)}
332:                   placeholder="Search movies..."
333:                   className="w-48 rounded-full border border-[rgba(124,58,237,0.12)] bg-[#FAFAF7] py-2 pl-10 pr-4 text-sm text-[#111827] outline-none transition placeholder:text-[#9CA3AF] focus:border-[#7C3AED] md:w-64"
334:                 />
335:               </div>
336:               <button
337:                 type="button"
338:                 onClick={openCreate}
339:                 className="flex items-center gap-2 rounded-full bg-[#7C3AED] px-3 py-2 text-sm font-semibold text-white shadow-[0_4px_16px_rgba(124,58,237,0.35)] transition hover:bg-[#6D28D9] sm:px-4"
340:               >
341:                 <Plus size={16} />
342:                 Add Movie
343:               </button>
344:             </div>
345:           </header>
346: 
347:           <div className="border-b border-[rgba(124,58,237,0.1)] bg-white/95 px-4 py-3 sm:hidden">
348:             <div className="relative">
349:               <Search size={16} className="pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 text-[#9CA3AF]" />
350:               <input
351:                 value={query}
352:                 onChange={(event) => setQuery(event.target.value)}
353:                 placeholder="Search movies..."
354:                 className="w-full rounded-full border border-[rgba(124,58,237,0.12)] bg-[#FAFAF7] py-2 pl-10 pr-4 text-sm text-[#111827] outline-none transition placeholder:text-[#9CA3AF] focus:border-[#7C3AED]"
355:               />
356:             </div>
357:           </div>
358: 
359:           {/* Content Area */}
360:           <div className="flex-1 overflow-y-auto p-6">
361:             {activeSection === "dashboard" && (
362:               <div className="space-y-6">
363:                 {/* Stats Cards */}
364:                 <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
365:                   <StatCard label="Total Movies" value={stats.totalMovies} icon={Film} color="#7C3AED" />
366:                   <StatCard label="Weekly Releases" value={stats.weeklyReleases} icon={Clock} color="#10B981" />
367:                   <StatCard label="Featured Movies" value={stats.featuredMovies} icon={Star} color="#F59E0B" />
368:                   <StatCard label="Platforms" value={stats.platforms} icon={Monitor} color="#3B82F6" />
369:                 </div>
370: 
371:                 {/* Recent Activity */}
372:                 <div className="rounded-xl border border-gray-200 bg-white shadow-[var(--card-shadow)] p-6">
373:                   <h2 className="text-lg font-semibold mb-4">Recent Movies</h2>
374:                   <div className="space-y-3">
375:                     {movies.slice(0, 5).map((movie) => (
376:                       <div key={movie.id} className="flex items-center justify-between p-3 rounded-lg bg-gray-50">
377:                         <div className="flex items-center gap-3">
378:                           <div className="w-10 h-10 rounded-lg bg-[#7C3AED]/20 flex items-center justify-center">
379:                             <Film size={16} className="text-[#7C3AED]" />
380:                           </div>
381:                           <div>
382:                             <div className="font-medium">{movie.title}</div>
383:                             <div className="text-xs text-[#6B7280]">{movie.ottPlatform} • {movie.year}</div>
384:                           </div>
385:                         </div>
386:                         <button onClick={() => openEdit(movie)} className="p-2 rounded-lg hover:bg-gray-100 transition-colors">
387:                           <Edit3 size={16} />
388:                         </button>
389:                       </div>
390:                     ))}
391:                   </div>
392:                 </div>
393:               </div>
394:             )}
395: 
396:             {activeSection === "moods" && (
397:               <div className="space-y-6">
398:                 <div className="rounded-xl border border-violet-100 bg-violet-50/80 p-4 text-sm text-[#4B5563] shadow-[var(--card-shadow)]">
399:                   <p className="font-medium text-[#111827]">How moods reach the homepage</p>
400:                   <p className="mt-2 leading-relaxed">
401:                     Each movie can have several moods. The public site filters the grid by the mood chips users tap (for example Love). Use{" "}
402:                     <span className="font-semibold text-[#5B21B6]">Add Movie</span> or the pencil on any row, then in the form scroll to{" "}
403:                     <span className="font-semibold text-[#5B21B6]">Moods</span> and tick every emotion that applies. Saving updates the site immediately (same browser).
404:                   </p>
405:                 </div>
406: 
407:                 <div className="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-3">
408:                   {MOODS.map((mood) => {
409:                     const inMood = movies.filter((m) => m.moods.includes(mood))
410:                     const emoji = getMoodEmoji(mood)
411:                     return (
412:                       <div key={mood} className="flex flex-col rounded-xl border border-gray-200 bg-white p-4 shadow-[var(--card-shadow)]">
413:                         <div className="flex items-start justify-between gap-2 border-b border-gray-100 pb-3">
414:                           <div className="flex min-w-0 items-center gap-2">
415:                             <span className="text-xl" aria-hidden>
416:                               {emoji}
417:                             </span>
418:                             <span className="truncate font-semibold text-[#111827]">{mood}</span>
419:                           </div>
420:                           <span className="shrink-0 rounded-full bg-violet-50 px-2 py-0.5 text-xs font-medium text-[#5B21B6]">{inMood.length}</span>
421:                         </div>
422:                         <ul className="mt-3 min-h-[4.5rem] flex-1 space-y-1 text-sm text-[#6B7280]">
423:                           {inMood.length === 0 ? (
424:                             <li className="italic text-[#9CA3AF]">No movies tagged yet</li>
425:                           ) : (
426:                             inMood.slice(0, 6).map((m) => (
427:                               <li key={m.id} className="truncate">
428:                                 {m.title}
429:                               </li>
430:                             ))
431:                           )}
432:                           {inMood.length > 6 ? <li className="text-xs text-[#9CA3AF]">+{inMood.length - 6} more</li> : null}
433:                         </ul>
434:                         <div className="mt-4 flex flex-wrap gap-2 border-t border-gray-100 pt-3">
435:                           <button
436:                             type="button"
437:                             onClick={() => openCreateWithMoods([mood])}
438:                             className="inline-flex items-center gap-1.5 rounded-lg bg-[#7C3AED] px-3 py-2 text-xs font-semibold text-white transition-colors hover:bg-[#6D28D9]"
439:                           >
440:                             <Plus size={14} />
441:                             Add movie
442:                           </button>
443:                           <button
444:                             type="button"
445:                             onClick={() => goToMovieLibraryForMood(mood)}
446:                             className="rounded-lg border border-gray-200 px-3 py-2 text-xs font-medium text-[#111827] transition-colors hover:bg-gray-50"
447:                           >
448:                             Open library
449:                           </button>
450:                         </div>
451:                       </div>
452:                     )
453:                   })}
454:                 </div>
455:               </div>
456:             )}
457: 
458:             {activeSection === "movies" && (
459:               <div className="rounded-xl border border-gray-200 bg-white shadow-[var(--card-shadow)] p-6">
460:                 <div className="flex items-center justify-between mb-6">
461:                   <h2 className="text-lg font-semibold">Movie Library</h2>
462:                   <div className="flex gap-2">
463:                     <select value={platformFilter} onChange={(event) => setPlatformFilter(event.target.value as OTTPlatform | "All")} className="rounded-lg border border-gray-200 bg-[#FAFAF7] px-3 py-2 text-sm text-[#111827] outline-none focus:border-[#7C3AED]">
464:                       <option>All Platforms</option>
465:                       {OTT_PLATFORMS.map((platform) => <option key={platform}>{platform}</option>)}
466:                     </select>
467:                     <select value={moodFilter} onChange={(event) => setMoodFilter(event.target.value as Mood | "All")} className="rounded-lg border border-gray-200 bg-[#FAFAF7] px-3 py-2 text-sm text-[#111827] outline-none focus:border-[#7C3AED]">
468:                       <option>All Moods</option>
469:                       {MOODS.map((mood) => <option key={mood}>{mood}</option>)}
470:                     </select>
471:                   </div>
472:                 </div>
473: 
474:                 <div className="overflow-x-auto">
475:                   <table className="w-full text-sm">
476:                     <thead className="text-xs uppercase tracking-wider text-[#6B7280]">
477:                       <tr>
478:                         <th className="text-left py-3 px-4">Movie</th>
479:                         <th className="text-left py-3 px-4">OTT</th>
480:                         <th className="text-left py-3 px-4">Moods</th>
481:                         <th className="text-left py-3 px-4">Rating</th>
482:                         <th className="text-left py-3 px-4">Flags</th>
483:                         <th className="text-right py-3 px-4">Actions</th>
484:                       </tr>
485:                     </thead>
486:                     <tbody className="divide-y divide-gray-200">
487:                       {filteredMovies.map((movie) => (
488:                         <tr key={movie.id} className="hover:bg-violet-50/80">
489:                           <td className="py-3 px-4">
490:                             <div className="font-medium">{movie.title}</div>
491:                             <div className="text-xs text-[#6B7280]">{movie.language} • {movie.year}</div>
492:                           </td>
493:                           <td className="py-3 px-4">{movie.ottPlatform}</td>
494:                           <td className="py-3 px-4">
495:                             <div className="flex flex-wrap gap-1">
496:                               {movie.moods.slice(0, 2).map((mood) => (
497:                                 <span key={mood} className="rounded-full bg-violet-50 px-2 py-0.5 text-xs text-[#5B21B6]">
498:                                   {mood}
499:                                 </span>
500:                               ))}
501:                               {movie.moods.length > 2 && <span className="text-xs text-[#6B7280]">+{movie.moods.length - 2}</span>}
502:                             </div>
503:                           </td>
504:                           <td className="py-3 px-4">{movie.rating.toFixed(1)}</td>
505:                           <td className="py-3 px-4 text-xs text-[#6B7280]">
506:                             {[movie.featured && "Featured", movie.trending && "Trending", movie.weeklyOTTRelease && "Weekly"].filter(Boolean).join(", ") || "-"}
507:                           </td>
508:                           <td className="py-3 px-4 text-right">
509:                             <div className="flex justify-end gap-2">
510:                               <button onClick={() => openEdit(movie)} className="p-2 rounded-lg hover:bg-gray-100 transition-colors">
511:                                 <Edit3 size={14} />
512:                               </button>
513:                               <button onClick={() => deleteMovie(movie.id)} className="p-2 rounded-lg hover:bg-red-500/20 text-red-400 transition-colors">
514:                                 <Trash2 size={14} />
515:                               </button>
516:                             </div>
517:                           </td>
518:                         </tr>
519:                       ))}
520:                     </tbody>
521:                   </table>
522:                 </div>
523:               </div>
524:             )}
525: 
526:             {activeSection === "weekly" && (
527:               <div className="rounded-xl border border-gray-200 bg-white shadow-[var(--card-shadow)] p-6">
528:                 <div className="flex items-center justify-between mb-6">
529:                   <h2 className="text-lg font-semibold">Weekly OTT Releases</h2>
530:                   <p className="text-sm text-[#6B7280]">Drag to reorder • Click to remove</p>
531:                 </div>
532: 
533:                 <div className="space-y-2">
534:                   {weeklyMovies.map((movie, index) => (
535:                     <div key={movie.id} className="flex items-center justify-between p-4 rounded-lg bg-gray-50 border border-gray-200">
536:                       <div className="flex items-center gap-4">
537:                         <div className="w-8 h-8 rounded-lg bg-[#7C3AED]/20 flex items-center justify-center text-sm font-bold text-[#A78BFA]">
538:                           {index + 1}
539:                         </div>
540:                         <div>
541:                           <div className="font-medium">{movie.title}</div>
542:                           <div className="text-xs text-[#6B7280]">{movie.ottPlatform} • {movie.language}</div>
543:                         </div>
544:                       </div>
545:                       <div className="flex gap-2">
546:                         <button onClick={() => moveWeekly(movie.id, -1)} className="p-2 rounded-lg hover:bg-gray-100 transition-colors" disabled={index === 0}>
547:                           ↑
548:                         </button>
549:                         <button onClick={() => moveWeekly(movie.id, 1)} className="p-2 rounded-lg hover:bg-gray-100 transition-colors" disabled={index === weeklyMovies.length - 1}>
550:                           ↓
551:                         </button>
552:                         <button onClick={() => updateMovie(movie.id, { weeklyOTTRelease: false })} className="p-2 rounded-lg hover:bg-red-500/20 text-red-400 transition-colors">
553:                           <X size={14} />
554:                         </button>
555:                       </div>
556:                     </div>
557:                   ))}
558:                   {weeklyMovies.length === 0 && (
559:                     <div className="text-center py-12 text-[#6B7280]">
560:                       <Clock size={32} className="mx-auto mb-3 opacity-50" />
561:                       <p>No weekly releases configured</p>
562:                     </div>
563:                   )}
564:                 </div>
565:               </div>
566:             )}
567: 
568:             {activeSection === "latest" && (
569:               <div className="rounded-xl border border-gray-200 bg-white shadow-[var(--card-shadow)] p-6">
570:                 <div className="flex items-center justify-between mb-6">
571:                   <h2 className="text-lg font-semibold">Latest Movies</h2>
572:                 </div>
573: 
574:                 <div className="overflow-x-auto">
575:                   <table className="w-full text-sm">
576:                     <thead className="text-xs uppercase tracking-wider text-[#6B7280]">
577:                       <tr>
578:                         <th className="text-left py-3 px-4">Movie</th>
579:                         <th className="text-left py-3 px-4">OTT</th>
580:                         <th className="text-left py-3 px-4">Status</th>
581:                         <th className="text-right py-3 px-4">Actions</th>
582:                       </tr>
583:                     </thead>
584:                     <tbody className="divide-y divide-gray-200">
585:                       {movies.filter(m => m.latestMovie).map((movie) => (
586:                         <tr key={movie.id} className="hover:bg-violet-50/80">
587:                           <td className="py-3 px-4">
588:                             <div className="font-medium">{movie.title}</div>
589:                             <div className="text-xs text-[#6B7280]">{movie.language} • {movie.year}</div>
590:                           </td>
591:                           <td className="py-3 px-4">{movie.ottPlatform}</td>
592:                           <td className="py-3 px-4">
593:                             <span className="px-2 py-0.5 rounded-full bg-green-500/20 text-green-400 text-xs">Active</span>
594:                           </td>
595:                           <td className="py-3 px-4 text-right">
596:                             <div className="flex justify-end gap-2">
597:                               <button onClick={() => openEdit(movie)} className="p-2 rounded-lg hover:bg-gray-100 transition-colors">
598:                                 <Edit3 size={14} />
599:                               </button>
600:                               <button onClick={() => updateMovie(movie.id, { latestMovie: false })} className="p-2 rounded-lg hover:bg-red-500/20 text-red-400 transition-colors">
601:                                 <X size={14} />
602:                               </button>
603:                             </div>
604:                           </td>
605:                         </tr>
606:                       ))}
607:                     </tbody>
608:                   </table>
609:                 </div>
610:               </div>
611:             )}
612: 
613:           </div>
614:         </div>
615:       </div>
616: 
617:       {modalOpen && (
618:         <div className="fixed inset-0 z-[100] overflow-y-auto bg-[#111827]/40 p-4 backdrop-blur-sm">
619:           <form onSubmit={saveMovie} className="mx-auto my-8 max-w-4xl rounded-2xl border border-gray-200 bg-white p-6 shadow-2xl">
620:             <div className="flex items-center justify-between border-b border-gray-200 pb-4 mb-6">
621:               <h2 className="text-xl font-semibold text-[#111827]">{draft.id ? "Edit Movie" : "Add Movie"}</h2>
622:               <button type="button" onClick={() => setModalOpen(false)} className="p-2 rounded-lg hover:bg-gray-100 transition-colors">
623:                 <X size={18} />
624:               </button>
625:             </div>
626: 
627:             <div className="grid gap-4 md:grid-cols-2 mb-6">
628:               <Field label="Movie Title"><input required value={draft.title} onChange={(event) => setDraft({ ...draft, title: event.target.value })} /></Field>
629:               <Field label="OTT Platform"><select value={draft.ottPlatform} onChange={(event) => setDraft({ ...draft, ottPlatform: event.target.value as OTTPlatform })}>{OTT_PLATFORMS.map((platform) => <option key={platform}>{platform}</option>)}</select></Field>
630:               <Field label="Language"><select value={draft.language} onChange={(event) => setDraft({ ...draft, language: event.target.value as MovieLanguage })}>{LANGUAGES.map((language) => <option key={language}>{language}</option>)}</select></Field>
631:               <Field label="Rating"><input type="number" min="0" max="10" step="0.1" value={draft.rating} onChange={(event) => setDraft({ ...draft, rating: Number(event.target.value) })} /></Field>
632:               <Field label="Release Year"><input type="number" value={draft.year} onChange={(event) => setDraft({ ...draft, year: Number(event.target.value) })} /></Field>
633:               <Field label="Duration"><input value={draft.duration} onChange={(event) => setDraft({ ...draft, duration: event.target.value })} /></Field>
634:               <Field label="Release Date"><input type="date" value={draft.releaseDate} onChange={(event) => setDraft({ ...draft, releaseDate: event.target.value })} /></Field>
635:               <Field label="YouTube Trailer"><input value={draft.youtubeTrailer} onChange={(event) => setDraft({ ...draft, youtubeTrailer: event.target.value })} /></Field>
636:               <div className="md:col-span-2 grid gap-4 md:grid-cols-2">
637:                 <MovieImageUpload
638:                   label="Upload Poster"
639:                   kind="poster"
640:                   slug={draft.title || "movie"}
641:                   storedPath={draft.customPoster ?? ""}
642:                   onPathChange={(path) => setDraft({ ...draft, customPoster: path })}
643:                   fallbackLabel="poster URL field below"
644:                 />
645:                 <MovieImageUpload
646:                   label="Upload Backdrop"
647:                   kind="backdrop"
648:                   slug={draft.title || "movie"}
649:                   storedPath={draft.customBackdrop ?? ""}
650:                   onPathChange={(path) => setDraft({ ...draft, customBackdrop: path })}
651:                   fallbackLabel="backdrop URL field below"
652:                 />
653:               </div>
654:               <Field label="Poster URL (fallback)"><input value={draft.poster} onChange={(event) => setDraft({ ...draft, poster: event.target.value })} /></Field>
655:               <Field label="Backdrop URL (fallback)"><input value={draft.backdrop ?? ""} onChange={(event) => setDraft({ ...draft, backdrop: event.target.value })} /></Field>
656:               <Field label="Gradient Accent"><input value={draft.gradientAccent} onChange={(event) => setDraft({ ...draft, gradientAccent: event.target.value })} /></Field>
657:               <Field label="Editorial Tagline"><input value={draft.editorialTagline ?? ""} onChange={(event) => setDraft({ ...draft, editorialTagline: event.target.value })} /></Field>
658:               <label className="md:col-span-2">
659:                 <span className="mb-2 block text-xs font-semibold uppercase tracking-wider text-[#6B7280]">Overview</span>
660:                 <textarea value={draft.overview} onChange={(event) => setDraft({ ...draft, overview: event.target.value })} className="min-h-20 w-full rounded-lg border border-gray-200 bg-[#FAFAF7] px-4 py-3 text-sm text-[#111827] outline-none transition-colors focus:border-[#7C3AED]" />
661:               </label>
662:             </div>
663: 
664:             <div className="mb-6" id="admin-modal-moods">
665:               <div className="mb-1 text-xs font-semibold uppercase tracking-wider text-[#6B7280]">Moods</div>
666:               <p className="mb-3 text-xs text-[#6B7280]">These tags control which mood rows on the public homepage include this title (users can pick Love, Comedy, and so on).</p>
667:               <div className="grid grid-cols-2 md:grid-cols-4 gap-2">
668:                 {MOODS.map((mood) => (
669:                   <label key={mood} className="flex cursor-pointer items-center gap-2 rounded-lg border border-gray-200 bg-[#FAFAF7] p-3 transition-colors hover:bg-gray-100">
670:                     <input
671:                       type="checkbox"
672:                       checked={draft.moods.includes(mood)}
673:                       onChange={(event) => {
674:                         setDraft({
675:                           ...draft,
676:                           moods: event.target.checked ? [...draft.moods, mood] : draft.moods.filter((item) => item !== mood),
677:                         })
678:                       }}
679:                       className="rounded border-gray-200 bg-gray-50 text-[#7C3AED] focus:ring-[#7C3AED]"
680:                     />
681:                     <span className="text-sm">{mood}</span>
682:                   </label>
683:                 ))}
684:               </div>
685:             </div>
686: 
687:             <div className="mb-6">
688:               <div className="mb-3 text-xs font-semibold uppercase tracking-wider text-[#6B7280]">Flags</div>
689:               <div className="grid grid-cols-2 md:grid-cols-3 gap-2">
690:                 {[
691:                   ["featured", "Featured"],
692:                   ["trending", "Trending"],
693:                   ["latestRelease", "Latest Release"],
694:                   ["heroFeatured", "Hero Featured"],
695:                   ["weeklyOTTRelease", "Weekly OTT"],
696:                   ["editorialPick", "Editorial Pick"],
697:                 ].map(([key, label]) => (
698:                   <label key={key} className="flex cursor-pointer items-center gap-2 rounded-lg border border-gray-200 bg-[#FAFAF7] p-3 transition-colors hover:bg-gray-100">
699:                     <input type="checkbox" checked={Boolean(draft[key as keyof DraftMovie])} onChange={(event) => setDraft({ ...draft, [key]: event.target.checked })} className="rounded border-gray-200 bg-gray-50 text-[#7C3AED] focus:ring-[#7C3AED]" />
700:                     <span className="text-sm">{label}</span>
701:                   </label>
702:                 ))}
703:               </div>
704:             </div>
705: 
706:             <div className="mb-6">
707:               <div className="mb-3 text-xs font-semibold uppercase tracking-wider text-[#6B7280]">Homepage Sections</div>
708:               <label className="flex cursor-pointer items-center gap-2 rounded-lg border border-gray-200 bg-[#FAFAF7] p-3 transition-colors hover:bg-gray-100 md:max-w-md">
709:                 <input
710:                   type="checkbox"
711:                   checked={Boolean(draft.latestMovie)}
712:                   onChange={(event) => setDraft({ ...draft, latestMovie: event.target.checked })}
713:                   className="rounded border-gray-200 bg-gray-50 text-[#7C3AED] focus:ring-[#7C3AED]"
714:                 />
715:                 <span className="text-sm">Latest Movies row on the homepage</span>
716:               </label>
717:             </div>
718: 
719:             <div className="flex justify-end gap-3 pt-4 border-t border-gray-200">
720:               <button type="button" onClick={() => setModalOpen(false)} className="rounded-lg border border-gray-200 px-4 py-2 text-sm font-medium text-[#111827] transition-colors hover:bg-gray-100">
721:                 Cancel
722:               </button>
723:               <button type="submit" className="flex items-center gap-2 rounded-lg bg-[#7C3AED] px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-[#6D28D9]">
724:                 <Save size={14} />
725:                 Save Movie
726:               </button>
727:             </div>
728:           </form>
729:         </div>
730:       )}
731:     </main>
732:   )
733: }
734: 
735: function StatCard({ label, value, icon: Icon, color }: { label: string; value: number; icon: any; color: string }) {
736:   return (
737:     <div className="rounded-xl border border-gray-200 bg-white shadow-[var(--card-shadow)] p-6">
738:       <div className="flex items-center justify-between mb-4">
739:         <Icon size={20} style={{ color }} />
740:         <span className="text-2xl font-bold text-[#111827]">{value}</span>
741:       </div>
742:       <div className="text-sm text-[#6B7280]">{label}</div>
743:     </div>
744:   )
745: }
746: 
747: function Field({ label, children }: { label: string; children: ReactElement }) {
748:   return (
749:     <label>
750:       <span className="mb-2 block text-xs font-semibold uppercase tracking-wider text-[#6B7280]">{label}</span>
751:       <div className="[&_input]:w-full [&_input]:rounded-lg [&_input]:border [&_input]:border-gray-200 [&_input]:bg-[#FAFAF7] [&_input]:px-4 [&_input]:py-2 [&_input]:text-sm [&_input]:text-[#111827] [&_input]:outline-none [&_input]:focus:border-[#7C3AED] [&_select]:w-full [&_select]:rounded-lg [&_select]:border [&_select]:border-gray-200 [&_select]:bg-[#FAFAF7] [&_select]:px-4 [&_select]:py-2 [&_select]:text-sm [&_select]:text-[#111827] [&_select]:outline-none [&_select]:focus:border-[#7C3AED]">
752:         {children}
753:       </div>
754:     </label>
755:   )
756: }
757: 
