# Admin panel (`/admin`) — required for login
# Copy to `.env.local` and set strong random values. Restart `next dev` after changes.

ADMIN_PASSWORD=change-this-to-a-long-random-phrase
ADMIN_SESSION_SECRET=use-another-long-random-string-for-signing-cookies

# Supabase — required for database connection
# Get these from your Supabase project settings

NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
